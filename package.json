{
  "name": "obsidian-money-root",
  "version": "1.0.0",
  "private": true,
  "scripts": {
    "start": "npm run start --prefix agent",
    "dev": "npm run dev --prefix agent",
    "watch-vault": "npm run watch-vault --prefix agent",
    "generate-pages": "npm run generate-pages --prefix agent",
    "cli": "npm run cli --prefix agent",
    "sheet:auth": "npx @google/clasp login",
    "sheet:push": "node google-sheets/push-sheet.mjs --prefix PEOPLE_SHEET_ --all",
    "sheet:push:all": "node google-sheets/push-sheet.mjs --prefix PEOPLE_SHEET_ --all",
    "sheet:push:lam": "node google-sheets/push-sheet.mjs --profile LAM --force"
  }
}
