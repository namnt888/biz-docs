        [
          {
            "node": "Duplicate Template Sheet",
            "type": "main",
            "index": 0
          }
        ]
      ]
    },
    "Duplicate Template Sheet": {
      "main": [
        [
          {
            "node": "GSheets (Append to Cycle Sheet)",
            "type": "main",
            "index": 0
          }
        ]
      ]
    }
  },
  "active": true,
  "settings": {},
  "versionId": "v1.5.1"
}